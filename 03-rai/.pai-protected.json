{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "Rai Protected Patterns — block these from leaking into git commits, public output, or memory writes",
  "version": "rai-1.0",
  "based_on": "PAI v4.0.3 .pai-protected.json (universal patterns) + custom Rai/local additions",
  "categories": {
    "api_keys": {
      "description": "API keys and tokens from common services",
      "patterns": [
        "sk-ant-api[a-zA-Z0-9-]{20,}",
        "sk-[a-zA-Z0-9]{20,}",
        "ANTHROPIC_API_KEY=[^$\\s]{10,}",
        "OPENAI_API_KEY=[^$\\s]{10,}",
        "PERPLEXITY_API_KEY=pplx-[a-zA-Z0-9]+",
        "ELEVENLABS_API_KEY=[a-f0-9]{32}",
        "GOOGLE_API_KEY=AIza[a-zA-Z0-9_-]{35}",
        "AKIA[0-9A-Z]{16}",
        "ABIA[0-9A-Z]{16}",
        "ACCA[0-9A-Z]{16}",
        "ASIA[0-9A-Z]{16}",
        "aws_access_key_id[\"'\\s:=]+[A-Z0-9]{20}",
        "aws_secret_access_key[\"'\\s:=]+[A-Za-z0-9/+=]{40}",
        "sk_live_[a-zA-Z0-9]{24,}",
        "pk_live_[a-zA-Z0-9]{24,}",
        "rk_live_[a-zA-Z0-9]{24,}",
        "AC[a-f0-9]{32}",
        "SK[a-f0-9]{32}",
        "SG\\.[a-zA-Z0-9_-]{22}\\.[a-zA-Z0-9_-]{43}",
        "dd[a-z]_[a-zA-Z0-9]{40}",
        "NRAK-[A-Z0-9]{27}",
        "sntrys_[a-zA-Z0-9]{64}",
        "AAAA[A-Za-z0-9_-]{7}:[A-Za-z0-9_-]{140}",
        "sbp_[a-f0-9]{40}",
        "eyJ[a-zA-Z0-9_-]*\\.[a-zA-Z0-9_-]*\\.[a-zA-Z0-9_-]*",
        "dop_v1_[a-f0-9]{64}",
        "do_[a-zA-Z0-9]{40,}",
        "npm_[a-zA-Z0-9]{36}",
        "pypi-[a-zA-Z0-9_-]{64,}",
        "glpat-[a-zA-Z0-9_-]{20,}",
        "glsa_[a-zA-Z0-9_-]{32,}",
        "tvly-[a-zA-Z0-9]{20,}",
        "xapi-[a-zA-Z0-9]{20,}"
      ]
    },
    "github_tokens": {
      "description": "GitHub authentication tokens",
      "patterns": [
        "ghp_[a-zA-Z0-9]{36}",
        "gho_[a-zA-Z0-9]{36}",
        "ghu_[a-zA-Z0-9]{36}",
        "ghs_[a-zA-Z0-9]{36}",
        "ghr_[a-zA-Z0-9]{36}",
        "github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]{59}",
        "GITHUB_TOKEN=[^$\\s]{10,}"
      ]
    },
    "slack_tokens": {
      "description": "Slack API tokens",
      "patterns": [
        "xoxb-[0-9]+-[0-9]+-[a-zA-Z0-9]+",
        "xoxp-[0-9]+-[0-9]+-[a-zA-Z0-9]+",
        "xoxa-[0-9]+-[a-zA-Z0-9]+",
        "xoxr-[0-9]+-[a-zA-Z0-9]+"
      ]
    },
    "webhooks": {
      "description": "Webhook URLs that could expose private channels",
      "patterns": [
        "https://discord\\.com/api/webhooks/[0-9]+/[a-zA-Z0-9_-]+",
        "https://discordapp\\.com/api/webhooks/[0-9]+/[a-zA-Z0-9_-]+",
        "https://hooks\\.slack\\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[a-zA-Z0-9]+",
        "https://hooks\\.zapier\\.com/hooks/catch/[0-9]+/[a-zA-Z0-9]+",
        "https://maker\\.ifttt\\.com/trigger/[^/]+/with/key/[a-zA-Z0-9_-]+"
      ]
    },
    "database_credentials": {
      "description": "Database connection strings with embedded credentials",
      "patterns": [
        "mongodb(\\+srv)?://[^:]+:[^@]+@[^/]+",
        "postgres(ql)?://[^:]+:[^@]+@[^/]+",
        "mysql://[^:]+:[^@]+@[^/]+",
        "redis://[^:]+:[^@]+@[^/]+",
        "DATABASE_URL=[^\\s]+:[^\\s]+@",
        "REDIS_URL=[^\\s]+:[^\\s]+@",
        "MONGO_URI=[^\\s]+:[^\\s]+@"
      ]
    },
    "private_keys": {
      "description": "Private keys and certificates",
      "patterns": [
        "-----BEGIN RSA PRIVATE KEY-----",
        "-----BEGIN OPENSSH PRIVATE KEY-----",
        "-----BEGIN PGP PRIVATE KEY-----",
        "-----BEGIN EC PRIVATE KEY-----",
        "-----BEGIN PRIVATE KEY-----",
        "-----BEGIN DSA PRIVATE KEY-----",
        "-----BEGIN ENCRYPTED PRIVATE KEY-----"
      ]
    },
    "pii_financial": {
      "description": "Financial identifiers (credit cards, SSN, EIN-style numbers, account/routing)",
      "patterns": [
        "SSN[:\\s]+[0-9]{3}-[0-9]{2}-[0-9]{4}",
        "EIN[:\\s]+[0-9]{2}-[0-9]{7}",
        "\\b[45][0-9]{3}[- ]?[0-9]{4}[- ]?[0-9]{4}[- ]?[0-9]{4}\\b",
        "\\b3[47][0-9]{2}[- ]?[0-9]{6}[- ]?[0-9]{5}\\b",
        "routing[_\\s]?number[:\\s]+[0-9]{9}",
        "account[_\\s]?number[:\\s]+[0-9]{8,17}"
      ]
    },
    "personal_emails": {
      "description": "Personal email addresses that should not leak to public output",
      "patterns": [
        "doe\\.s\\.john@example\\.com",
        "doe\\.s\\.john@[a-z]+\\.[a-z]+"
      ]
    },
    "private_paths": {
      "description": "Local file system paths that reveal account name or private layout",
      "patterns": [
        "~/(?!helm/$)",
        "~/(?!helm/$)",
        "/Users/[a-z]+/\\.claude/(?!skills/[A-Z])",
        "/home/[a-z]+/\\.claude/(?!skills/[A-Z])"
      ]
    },
    "internal_infrastructure": {
      "description": "Internal hostnames, IPs, and URLs. Lookbehind/lookahead guards exclude common version-string false positives (e.g. `nvidia_curand-10.0.0.1-...` in lockfiles, `version = \"10.0.0.1\"` literals, `10.0.0.1.dev0` etc).",
      "patterns": [
        "(?<![-\"])\\b10\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\b(?![-.])",
        "(?<![-\"])\\b172\\.(1[6-9]|2[0-9]|3[0-1])\\.[0-9]{1,3}\\.[0-9]{1,3}\\b(?![-.])",
        "(?<![-\"])\\b192\\.168\\.[0-9]{1,3}\\.[0-9]{1,3}\\b(?![-.])",
        "\\.internal\\.",
        "\\.local\\.",
        "\\.corp\\.",
        "\\.private\\."
      ]
    },
    "credentials_inline": {
      "description": "Inline credentials and bearer tokens. The password/secret patterns require an `=` or `:` separator so prose like \"secret scanning\" or \"password recovery\" does NOT match — only key-value shapes like `password=...` / `secret: ...` do.",
      "patterns": [
        "password[\"']?\\s*[:=]\\s*[\"']?[^$\\s\"']{8,}(?!.*placeholder|.*example|.*YOUR_)",
        "secret[\"']?\\s*[:=]\\s*[\"']?[^$\\s\"']{8,}(?!.*placeholder|.*example|.*YOUR_)",
        "API_KEY=['\"][a-zA-Z0-9_-]{16,}['\"]",
        "SECRET_KEY=['\"][a-zA-Z0-9_-]{16,}['\"]",
        "Bearer [a-zA-Z0-9_-]{20,}",
        "Authorization:[\\s]+Bearer [a-zA-Z0-9_-]+"
      ]
    },
    "cloudflare": {
      "description": "Cloudflare credentials and account identifiers",
      "patterns": [
        "CLOUDFLARE_API_TOKEN=[a-zA-Z0-9_-]{40}",
        "CLOUDFLARE_API_KEY=[a-f0-9]{37}",
        "CF_API_TOKEN=[a-zA-Z0-9_-]{40}",
        "CLOUDFLARE_ZONE_ID=[a-f0-9]{32}",
        "CLOUDFLARE_ACCOUNT_ID=[a-f0-9]{32}"
      ]
    },
    "locale_identity": {
      "description": "The owner's family names and personal contact identifiers (gated by context) that should not leak to public commits or AI-visible content",
      "patterns": [
        "\\bSam\\b(?=.*John|.*Doe|.*family|.*kid|.*child)",
        "\\bZoe\\b(?=.*John|.*Doe|.*family|.*kid|.*child)",
        "\\bJane\\b(?=.*John|.*Doe|.*family|.*wife)",
        "\\+1\\s*\\(?[0-9]{3}\\)?[\\s.-]*[0-9]{3}[\\s.-]*[0-9]{4}",
        "\\b[0-9]{3}[\\s.-][0-9]{3}[\\s.-][0-9]{4}\\b",
        "Austin,?\\s*(TX|Texas|USA)",
        "\\b[0-9]{3}-[0-9]{2}-[0-9]{4}\\b"
      ],
      "severity": "medium"
    },
    "ai_attribution": {
      "description": "AI / Claude / Anthropic mentions that must NOT appear in git commits, PRs, or any GitHub-visible content",
      "patterns": [
        "Co-Authored-By:[\\s]+Claude",
        "Co-Authored-By:[\\s]+.*<noreply@anthropic\\.com>",
        "Generated with Claude Code",
        "Generated with .* AI",
        "🤖[\\s]+Generated",
        "powered by Claude"
      ],
      "severity": "high",
      "scope": "git_only"
    },
    "misc_sensitive": {
      "description": "Miscellaneous sensitive file references",
      "patterns": [
        "id_rsa(?!\\.pub)",
        "id_ed25519(?!\\.pub)",
        "id_ecdsa(?!\\.pub)",
        "\\.pem$",
        "\\.key$",
        "\\.p12$",
        "\\.pfx$",
        "service[_-]account.*\\.json"
      ]
    }
  },
  "exception_contexts": {
    "description": "Patterns that are OK when in clearly documentation/example context",
    "allowed_prefixes": [
      "# Example:",
      "// Example:",
      "/* Example",
      "e.g.,",
      "for example",
      "placeholder",
      "YOUR_",
      "EXAMPLE",
      "<your-",
      "documentation",
      "pattern:",
      "regex:",
      "matches:",
      "// Pattern",
      "# Pattern",
      "sample",
      "template",
      "default:",
      "fallback",
      "config example",
      "format:",
      "(xxx)",
      "xxx-xxx",
      "secret detection",
      "detect secret",
      "find secret",
      "scan for",
      "pattern match",
      "regex match",
      "localhost:",
      "http://localhost",
      "127.0.0.1",
      "192.168.x.x",
      "10.x.x.x",
      "private IP",
      "internal IP",
      "example IP",
      "ANTHROPIC_API_KEY=your",
      "your_api_key"
    ]
  },
