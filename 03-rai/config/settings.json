  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"$(command -v node || ls -t $HOME/.nvm/versions/node/*/bin/node 2>/dev/null | head -1)\" \"${plugin_dir}dist/index.js\"'"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "allow": [
      "$defaults",
      "Read-only SSH to the personal investment paper-trading bot at root@203.0.113.10 using the ~/.ssh/spot-bot key (used only by the /investment status and /investment ops skills) is allowed. The probe runs `docker inspect`, `curl` against the loopback freqUI API at 127.0.0.1:8080, and `cat` of /opt/paper-portfolio/portfolio_state.json to read status. It is a dry-run/paper bot: the probe never places trades, restarts services, or edits config. The freqUI password is fetched at runtime and never echoed \u2014 reading it into a shell variable to make an authenticated localhost API call is expected and approved."
    ]
  },
